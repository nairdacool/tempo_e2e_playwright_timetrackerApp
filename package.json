{
  "name": "playwright-tempo-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:clean": "rm -rf allure-results allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "qasphere:upload": "qasphere playwright-json-upload --project-code TEM test-results/results.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "allure-commandline": "^2.37.0",
    "allure-js-commons": "^3.6.0",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1",
    "qas-cli": "^0.4.6",
    "typescript": "^5.9.3"
  }
}
